---
import Layout from "../../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const videoId = project.data.youtubeId || 
                (project.data.youtubeIds && project.data.youtubeIds[0]) || 
                '';
const hasPlaylist = project.data.youtubeIds && project.data.youtubeIds.length > 1;
const playlistVideos = project.data.youtubeIds || [];

// Use project description for SEO or fallback to default
const pageDescription = project.data.description || `Watch ${project.data.title} — a ${project.data.category} produced by Avakkai Studio for ${project.data.client}.`;
---

<Layout title={`${project.data.title} — Avakkai Studio`} description={pageDescription}>
  <article class="bg-brand-dark min-h-screen">
    {/* Hero Video Section */}
    <section class="relative w-full bg-black">
      <div class="aspect-video w-full max-w-7xl mx-auto">
        {videoId ? (
          <iframe 
            class="w-full h-full"
            src={`https://www.youtube.com/embed/${videoId}`}
            title={project.data.title}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          />
        ) : (
          <div class="w-full h-full flex items-center justify-center bg-brand-dark text-zinc-500">
            No video available
          </div>
        )}
      </div>
    </section>

    {/* Project Details */}
    <section class="max-w-4xl mx-auto px-6 py-16 lg:py-24">
      {/* Header */}
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-4 flex-wrap">
          <span class="text-[10px] font-mono uppercase tracking-wider px-3 py-1 bg-brand-card border border-brand-border text-brand-secondary rounded">
            {project.data.category}
          </span>
          {project.data.tags && project.data.tags.map((tag) => (
            <span class="text-xs text-zinc-500 font-light">#{tag}</span>
          ))}
        </div>
        <h1 class="text-4xl md:text-5xl font-black text-white font-display leading-tight mb-3">
          {project.data.title}
        </h1>
        <p class="text-lg text-zinc-400 font-light">
          Client: <span class="text-white font-medium">{project.data.client}</span>
        </p>
        {project.data.highlight && (
          <p class="text-sm text-brand-secondary mt-2 font-mono">
            ★ {project.data.highlight}
          </p>
        )}
        {project.data.date && (
          <p class="text-xs text-zinc-600 mt-2 font-mono">
            {project.data.date}
          </p>
        )}
      </div>

      {/* Description */}
      {project.data.description && (
        <div class="mb-12 pb-12 border-b border-brand-border">
          <h2 class="text-sm font-mono text-brand-primary uppercase tracking-wider mb-4">
            Overview
          </h2>
          <p class="text-zinc-300 text-lg leading-relaxed font-light">
            {project.data.description}
          </p>
        </div>
      )}

      {/* Markdown Content */}
      <div class="prose prose-invert prose-headings:font-display prose-headings:text-white prose-p:text-zinc-300 prose-p:leading-relaxed prose-strong:text-white prose-ul:text-zinc-300 prose-li:text-zinc-300 prose-a:text-brand-primary prose-a:no-underline hover:prose-a:underline prose-hr:border-brand-border max-w-none">
        <Content />
      </div>

      {/* Playlist (if multiple videos) */}
      {hasPlaylist && playlistVideos.length > 1 && (
        <div class="mt-16 pt-12 border-t border-brand-border">
          <h2 class="text-sm font-mono text-brand-primary uppercase tracking-wider mb-6">
            More from this project
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {playlistVideos.slice(1).map((id) => (
              <div class="aspect-video bg-black rounded-xl overflow-hidden">
                <iframe
                  class="w-full h-full"
                  src={`https://www.youtube.com/embed/${id}`}
                  title={`${project.data.title} - Additional`}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                />
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Back Navigation */}
      <div class="mt-16 pt-8 border-t border-brand-border">
        <a 
          href="/#work" 
          class="inline-flex items-center gap-2 text-zinc-400 hover:text-white transition-colors font-mono text-sm"
        >
          ← Back to all work
        </a>
      </div>
    </section>
  </article>
</Layout>