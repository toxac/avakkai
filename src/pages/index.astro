---
import Layout from "../layouts/Layout.astro";
import ProjectViewer from "../components/ProjectViewer.jsx";
import { getCollection } from "astro:content";

const finalProjects = await getCollection("projects");
import ashvinImage from "../assets/images/ashvin.png";

const brands = [
  "Tata",
  "Gatorade",
  "Cult.fit",
  "TVS Motors",
  "UB Group",
  "Britannia",
  "Abhibus",
  "Planet Fashion",
  "Sonata",
  "ING",
  "Garuda Foods",
  "Pepsico",
  "UniverCell",
];
---

<Layout title="Avakkai Studio — TV & Digital Ad Production">
  <section
    class="relative flex flex-col justify-center overflow-hidden bg-brand-dark"
  >
    <div class="absolute inset-0 z-0 overflow-hidden">
      <div
        class="absolute inset-0 bg-gradient-to-r from-brand-dark via-brand-dark/80 to-transparent z-10"
      >
      </div>
      <div class="absolute inset-0 bg-black/40 z-10"></div>
      <video
        autoplay
        muted
        loop
        playsinline
        preload="none"
        poster="/images/hero-poster.webp"
        class="w-full h-full object-cover scale-[1.02] filter brightness-[0.5] contrast-[1.05]"
      >
        <source src="/video/hero.webm" type="video/webm" />
        <source src="/video/hero.mp4" type="video/mp4" />
      </video>
    </div>

    <div
      class="relative w-full max-w-7xl mx-auto px-6 lg:px-10 z-20 flex flex-col justify-center"
    >
      <!-- Top padding: controls space from navbar -->
      <div class="pt-24 sm:pt-24 lg:pt-32"></div>

      <div class="max-w-3xl">
        <div class="mb-2 sm:mb-4 lg:mb-6">
          <p
            class="text-brand-secondary text-[8px] sm:text-[10px] lg:text-xs tracking-[0.2em] sm:tracking-[0.3em] uppercase font-body font-bold"
          >
            TV Commercials · Digital Films · Campaigns
          </p>
        </div>

        <h1
          class="text-5xl sm:text-5xl md:text-7xl lg:text-8xl font-black text-white leading-[0.95] tracking-tight mb-3 sm:mb-5 lg:mb-8 font-display"
        >
          Films that move<br />
          <span class="text-brand-secondary italic font-normal font-display"
            >people</span
          > —<br />
          and metrics.
        </h1>

        <!-- More prominent description -->
        <p
          class="text-lg sm:text-xl md:text-2xl lg:text-3xl leading-relaxed max-w-xl font-medium text-zinc-200"
        >
          25 years of storytelling across TV and digital — crafting premium
          films, commercials, and branded content that move audiences and drive
          results.
        </p>
      </div>

      <!-- Stats Grid -->
      <div
        class="grid grid-cols-3 gap-2 sm:gap-6 lg:gap-8 text-white mt-6 sm:mt-12 lg:mt-20 pt-4 sm:pt-6 lg:pt-10 border-t border-brand-border/40 max-w-2xl"
      >
        <div>
          <p
            class="text-xl sm:text-2xl md:text-4xl lg:text-5xl font-black font-display text-brand-secondary"
          >
            25+
          </p>
          <p
            class="text-[9px] sm:text-[10px] lg:text-xs uppercase tracking-widest mt-0.5 font-body text-zinc-300 font-semibold"
          >
            Years of Craft
          </p>
        </div>
        <div class="text-center">
          <p
            class="text-xl sm:text-2xl md:text-4xl lg:text-5xl font-black font-display text-brand-secondary"
          >
            75+
          </p>
          <p
            class="text-[9px] sm:text-[10px] lg:text-xs uppercase tracking-widest mt-0.5 font-body text-zinc-300 font-semibold"
          >
            Brands Served
          </p>
        </div>
        <div class="text-right">
          <p
            class="text-xl sm:text-2xl md:text-4xl lg:text-5xl font-black font-display text-brand-secondary"
          >
            10+
          </p>
          <p
            class="text-[9px] sm:text-[10px] lg:text-xs uppercase tracking-widest mt-0.5 font-body text-zinc-300 font-semibold"
          >
            Industry Awards
          </p>
        </div>
      </div>

      <!-- Bottom padding: controls space before next section -->
      <div class="pb-12 sm:pb-16 lg:pb-20"></div>
    </div>

    <div
      class="absolute bottom-0 left-0 w-full h-[1px] bg-gradient-to-r from-brand-primary via-brand-border to-transparent"
    >
    </div>
  </section>

  <section id="work" class="py-28 px-6 max-w-7xl mx-auto">
    <div class="mb-16">
      <p
        class="text-brand-secondary text-xs tracking-[0.25em] uppercase font-body font-semibold mb-3"
      >
        Selected Portfolio
      </p>
      <h2
        class="text-4xl md:text-6xl font-bold font-display tracking-tight text-white"
      >
        Stories we've told.
      </h2>
    </div>

    <ProjectViewer client:visible initialProjects={finalProjects} />
  </section>

  <!-- BRAND MARQUEE SECTION -->
  <section class="bg-black py-14 relative z-10 overflow-hidden">
    <!-- Row 1: Static Title Header -->
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <p
        class="text-center text-xs text-zinc-500 tracking-[0.25em] uppercase mb-10 font-body font-semibold"
      >
        Brands we've worked with
      </p>
    </div>

    <!-- Row 2: Infinite Scrolling Marquee Track -->
    <div
      class="relative w-full overflow-hidden flex select-none masking-fade gap-16"
    >
      <!-- Primary Track Loop -->
      <div
        class="flex flex-nowrap shrink-0 items-center gap-16 min-w-full animate-marquee-scroll"
      >
        {
          brands.map((brand) => (
            <span class="text-white text-base md:text-lg font-bold opacity-75 hover:opacity-100 hover:text-brand-secondary transition-all font-display tracking-wide whitespace-nowrap cursor-default">
              {brand}
            </span>
          ))
        }
      </div>

      <!-- Duplicate Track Loop -->
      <div
        class="flex flex-nowrap shrink-0 items-center gap-16 min-w-full animate-marquee-scroll"
        aria-hidden="true"
      >
        {
          brands.map((brand) => (
            <span class="text-white text-base md:text-lg font-bold opacity-75 hover:opacity-100 hover:text-brand-secondary transition-all font-display tracking-wide whitespace-nowrap cursor-default">
              {brand}
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- THE CASE FOR VIDEO IN THE ATTENTION ECONOMY -->
  <section class="bg-brand-dark border-b border-brand-border py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Left Column: Strategic Value Proposition -->
        <div>
          <p
            class="text-brand-primary text-xs tracking-[0.25em] uppercase font-body font-bold mb-4"
          >
            The Attention Economy
          </p>
          <h2
            class="text-4xl md:text-5xl font-bold text-white leading-tight mb-6 font-display"
          >
            Stop competing for attention. Command it.
          </h2>
          <p class="text-zinc-400 text-lg leading-relaxed mb-8 font-light">
            In the modern marketplace, static content is invisible. Video is no
            longer just a component of your marketing mix—it is the primary
            driver of brand growth. From legacy TV campaigns that establish
            institutional authority to high-velocity digital films on YouTube
            and Instagram that drive immediate action, cinematic storytelling is
            how premium brands win markets. We capture that split-second window
            of consumer focus and translate it directly into commercial scale.
          </p>
        </div>

        <!-- Right Column: Operational Core Capabilities -->
        <div class="grid grid-cols-2 gap-4 font-sans">
          <div class="bg-brand-card p-6 border border-brand-border rounded-xl">
            <h3 class="font-bold text-white mb-2 font-display text-base">
              TV Commercials
            </h3>
            <p class="text-xs text-zinc-400 leading-relaxed">
              30-sec and 60-sec brand films engineered for broadcast impact.
            </p>
          </div>
          <div class="bg-brand-card p-6 border border-brand-border rounded-xl">
            <h3 class="font-bold text-white mb-2 font-display text-base">
              Digital Films
            </h3>
            <p class="text-xs text-zinc-400 leading-relaxed">
              Social-first content crafted for scroll-stopping performance.
            </p>
          </div>
          <div class="bg-brand-card p-6 border border-brand-border rounded-xl">
            {
              /* High-profile productions with A-list talent, supported by past projects[cite: 1] */
            }
            <h3 class="font-bold text-white mb-2 font-display text-base">
              Celebrity Campaigns
            </h3>
            <p class="text-xs text-zinc-400 leading-relaxed">
              High-profile productions with A-list talent, seamlessly executed.
            </p>
          </div>
          <div class="bg-brand-card p-6 border border-brand-border rounded-xl">
            {
              /* Multi-market campaigns with region-specific talent, supported by TVS campaigns[cite: 1] */
            }
            <h3 class="font-bold text-white mb-2 font-display text-base">
              International Markets
            </h3>
            <p class="text-xs text-zinc-400 leading-relaxed">
              Multi-market campaigns with region-specific talent and creative.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT SECTION WITH IMAGE ARCHITECTURE -->
  <section
    id="about"
    class="bg-brand-card border-y border-brand-border py-28 px-6"
  >
    <div
      class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center"
    >
      <!-- Left Column: Cinematic Portrait / Image Frame -->
      <div
        class="lg:col-span-5 relative group overflow-hidden border border-brand-border rounded-2xl aspect-[4/5] bg-brand-dark"
      >
        <img
          src={ashvinImage.src}
          alt="Ashvin — Director & Founder"
          class="w-full h-full object-cover opacity-70 group-hover:opacity-100 group-hover:scale-102 transition-all duration-700 ease-out"
          loading="lazy"
        />
        <div
          class="absolute inset-0 bg-gradient-to-t from-brand-dark via-transparent to-transparent opacity-80 pointer-events-none"
        >
        </div>
      </div>

      <!-- Right Column: Condensed Editorial Copy -->
      <div class="lg:col-span-7 space-y-6">
        <div>
          <span
            class="text-brand-primary font-mono text-xs uppercase tracking-widest font-bold"
            >// Directorial Pedigree</span
          >
          <h2
            class="text-4xl md:text-5xl font-black text-white mt-2 tracking-tight font-display"
          >
            The Vision Behind Avakkai
          </h2>
        </div>

        <div
          class="space-y-6 text-zinc-300 font-light text-base leading-relaxed"
        >
          <p>
            Twenty-five years of elite commercial filmmaking and high-impact
            storytelling form the foundational DNA of Avakkai Studio.
          </p>
          <p>
            From working alongside industry vanguard R. Balki as an Associate
            Director on the sets of <em>Cheeni Kum</em> to directing a monumental
            social awareness campaign that reached <strong
              class="text-brand-secondary font-medium"
              >16 million views in under 24 hours</strong
            >, director <strong class="text-white font-medium">Ashvin</strong> has
            consistently pushed the boundaries of moving images.
          </p>
          <p>
            He has engineered Avakkai into a seamless, borderless, turnkey
            production ecosystem. Our focus is singular: executing gripping,
            premium visual narratives backed by ironclad strategy to drive
            commercial scale for brands across the globe.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CULTURAL IMPACT SECTION -->
  <section
    class="bg-brand-dark py-16 sm:py-24 lg:py-32 text-white relative overflow-hidden"
  >
    <div class="absolute inset-0 opacity-5 pointer-events-none">
      <div class="absolute top-0 left-1/4 w-[1px] h-full bg-white"></div>
      <div class="absolute top-0 left-2/4 w-[1px] h-full bg-white"></div>
      <div class="absolute top-0 left-3/4 w-[1px] h-full bg-white"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10">
      <div
        class="grid grid-cols-1 lg:grid-cols-12 gap-8 sm:gap-12 lg:gap-16 items-start"
      >
        <!-- Left Column: Main Content -->
        <div class="lg:col-span-7 space-y-4 sm:space-y-6">
          <div class="inline-flex items-center gap-2 mb-1 sm:mb-2">
            <span class="w-2 h-2 rounded-full bg-brand-primary animate-pulse"
            ></span>
            <p
              class="text-brand-secondary text-[10px] sm:text-xs tracking-widest uppercase font-body font-semibold"
            >
              Cultural Impact
            </p>
          </div>

          <h3
            class="text-3xl sm:text-4xl md:text-6xl font-black font-display leading-[1.05] tracking-tight text-white"
          >
            "Reached <span class="text-brand-secondary italic font-normal"
              >16 million views</span
            > in under 24 hours."
          </h3>

          <p
            class="text-zinc-400 text-base sm:text-lg leading-relaxed max-w-xl"
          >
            That's the power of a story told with absolute intention. Our <span
              class="text-white font-medium">Stand Up</span
            > social awareness campaign proved that purposeful filmmaking moves cultural
            metrics—not just audiences.
          </p>
        </div>

        <!-- Right Column: Awards & Honors -->
        <div class="lg:col-span-5">
          <div class="lg:pl-6">
            <p
              class="text-[10px] uppercase tracking-[0.3em] text-zinc-500 mb-4 sm:mb-6 font-body font-medium"
            >
              Official Showcases & Honors
            </p>
            <!-- Awards as row on mobile, column on desktop -->
            <div class="grid grid-cols-3 lg:grid-cols-1 gap-4 sm:gap-6">
              <!-- Award 1 -->
              <div
                class="group border-l border-brand-border pl-3 sm:pl-4 hover:border-brand-secondary transition-all duration-300"
              >
                <p
                  class="text-white font-bold text-sm sm:text-base tracking-tight font-display"
                >
                  Silver Abby
                </p>
                <p class="text-zinc-500 text-[10px] sm:text-xs mt-0.5">
                  Goafest
                </p>
                <p
                  class="text-brand-secondary font-semibold font-body text-[8px] sm:text-[10px] tracking-wider uppercase mt-1 sm:mt-2"
                >
                  Winner 2017
                </p>
              </div>

              <!-- Award 2 -->
              <div
                class="group border-l border-brand-border pl-3 sm:pl-4 hover:border-brand-secondary transition-all duration-300"
              >
                <p
                  class="text-white font-bold text-sm sm:text-base tracking-tight font-display"
                >
                  Kyoorius
                </p>
                <p class="text-zinc-500 text-[10px] sm:text-xs mt-0.5">
                  Creative Review
                </p>
                <p
                  class="text-zinc-400 font-medium font-body text-[8px] sm:text-[10px] tracking-wider uppercase mt-1 sm:mt-2"
                >
                  Shortlisted
                </p>
              </div>

              <!-- Award 3 -->
              <div
                class="group border-l border-brand-border pl-3 sm:pl-4 hover:border-brand-secondary transition-all duration-300"
              >
                <p
                  class="text-white font-bold text-sm sm:text-base tracking-tight font-display"
                >
                  3 Elephants
                </p>
                <p class="text-zinc-500 text-[10px] sm:text-xs mt-0.5">
                  In-Book Showcase
                </p>
                <p
                  class="text-brand-secondary font-semibold font-body text-[8px] sm:text-[10px] tracking-wider uppercase mt-1 sm:mt-2"
                >
                  Kyoorius 2017
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS SECTION -->
  <section
    class="bg-brand-dark py-32 text-white relative overflow-hidden border-t border-brand-border"
  >
    <div class="absolute inset-0 opacity-5 pointer-events-none">
      <div class="absolute top-0 left-1/4 w-[1px] h-full bg-white"></div>
      <div class="absolute top-0 left-2/4 w-[1px] h-full bg-white"></div>
      <div class="absolute top-0 left-3/4 w-[1px] h-full bg-white"></div>
    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10">
      <div class="text-center mb-16">
        <p
          class="text-[10px] uppercase tracking-[0.3em] text-zinc-500 font-body font-medium"
        >
          Studio Reputation
        </p>
        <h2
          class="text-3xl md:text-4xl font-black text-white font-display mt-4"
        >
          What Our <span class="text-brand-secondary italic font-normal"
            >Clients</span
          > Say
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-6xl mx-auto">
        <!-- Testimonial 1 -->
        <div
          class="relative bg-brand-card border border-brand-border p-8 hover:border-zinc-700 transition-colors shadow-2xl group rounded-xl"
        >
          <span
            class="absolute top-0 left-0 w-[2px] h-0 bg-brand-primary group-hover:h-full transition-all duration-300"
          ></span>
          <p
            class="text-zinc-300 font-light text-base leading-relaxed italic mb-6"
          >
            "Ashvin brings a filmmaker's eye to every brief — bold concepts,
            flawless production coordination, and visual results that speak for
            themselves."
          </p>
          <div
            class="flex items-center justify-between pt-4 border-t border-brand-border"
          >
            <div>
              <p class="text-white font-medium text-xs tracking-wide">
                Brand Management Team
              </p>
              <p
                class="text-zinc-500 text-[10px] uppercase tracking-wider mt-0.5"
              >
                International Campaign
              </p>
            </div>
            <span
              class="text-brand-border text-4xl font-display font-black group-hover:text-brand-secondary transition-colors"
              >"</span
            >
          </div>
        </div>

        <!-- Testimonial 2 -->
        <div
          class="relative bg-brand-card border border-brand-border p-8 hover:border-zinc-700 transition-colors shadow-2xl group rounded-xl"
        >
          <span
            class="absolute top-0 left-0 w-[2px] h-0 bg-brand-primary group-hover:h-full transition-all duration-300"
          ></span>
          <p
            class="text-zinc-300 font-light text-base leading-relaxed italic mb-6"
          >
            "The TVS Africa documentary series was delivered seamlessly —
            completely right talent, authentic locale look and feel, tightly on
            schedule and completely on brief."
          </p>
          <div
            class="flex items-center justify-between pt-4 border-t border-brand-border"
          >
            <div>
              <p class="text-white font-medium text-xs tracking-wide">
                Marketing & Communications Lead
              </p>
              <p
                class="text-zinc-500 text-[10px] uppercase tracking-wider mt-0.5"
              >
                TVS Motors International
              </p>
            </div>
            <span
              class="text-brand-border text-4xl font-display font-black group-hover:text-brand-secondary transition-colors"
              >"</span
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- REFINED NEUTRAL CTA SECTION -->
  <section
    id="contact"
    class="bg-brand-dark py-24 border-t border-brand-border relative"
  >
    <!-- Subtle brand primary background ambient blur -->
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-brand-primary/5 rounded-full blur-3xl pointer-events-none"
    >
    </div>

    <div class="max-w-4xl mx-auto px-6 lg:px-10 text-center relative z-10">
      <h2
        class="text-4xl md:text-5xl font-black text-white mb-6 font-display leading-tight"
      >
        Ready to make something<br /><em class="not-italic text-brand-secondary"
          >unforgettable?</em
        >
      </h2>
      <p class="text-zinc-400 text-lg mb-12 max-w-xl mx-auto font-light">
        Whether it's a 30-second TVC or a campaign spanning continents — we
        build stories that work.
      </p>

      <!-- Contact Channels -->
      <div
        class="flex flex-col sm:flex-row gap-4 sm:gap-8 justify-center items-center text-zinc-300 font-mono text-base mb-10"
      >
        <a
          href="mailto:reach@avakkai.studio"
          class="hover:text-brand-secondary transition-colors flex items-center gap-2"
        >
          <span class="text-brand-primary">@</span> reach@avakkai.studio
        </a>
        <span class="hidden sm:inline text-brand-border">|</span>
        <a
          href="tel:9611104445"
          class="hover:text-brand-secondary transition-colors flex items-center gap-2"
        >
          <span class="text-brand-primary">#</span> +91 96111 04445
        </a>
      </div>

      <!-- Divider -->
      <div class="flex items-center gap-6 justify-center mb-10">
        <span class="h-px w-24 bg-brand-border"></span>
      </div>

      <!-- Company Profile PDF Download -->
      <div>
        <a
          href="/avakkai_profile.pdf"
          download
          class="inline-flex items-center gap-3 bg-brand-primary/10 hover:bg-brand-primary/20 text-brand-secondary font-bold px-8 py-4 text-sm tracking-widest uppercase rounded-xl border border-brand-primary/20 hover:border-brand-primary/40 transition-all shadow-lg hover:shadow-brand-primary/10"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
            ></path>
          </svg>
          Download Company Profile
          <span class="text-[8px] text-zinc-500 font-mono tracking-widest"
            >PDF</span
          >
        </a>
        <p class="text-zinc-600 text-[10px] font-mono mt-3 tracking-wide">
          Portfolio, capabilities & case studies
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes marquee {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(-100%);
    }
  }

  .animate-marquee-scroll {
    animation: marquee 35s linear infinite;
  }

  /* Creates a high-end cinematic fade on the edges of the screen */
  .masking-fade {
    mask-image: linear-gradient(
      to right,
      transparent,
      black 15%,
      black 85%,
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 15%,
      black 85%,
      transparent
    );
  }
</style>
